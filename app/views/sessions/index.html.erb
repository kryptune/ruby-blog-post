<div class="min-h-screen bg-zinc-950 text-zinc-100 font-mono p-8">

  <%# Header %>
  <div class="max-w-3xl mx-auto">
    <div class="flex items-center justify-between mb-12">
      <div>
        <p class="text-xs tracking-[0.3em] text-zinc-500 uppercase mb-1">Security</p>
        <h1 class="text-2xl font-bold tracking-tight">Active Sessions</h1>
      </div>
      <%= button_to web_logout_all_path,
          method: :delete,
          data: { turbo_method: :delete, turbo_confirm: "This will log you out from every device. Continue?" },
          class: "group flex items-center gap-2 px-4 py-2 border border-red-800 text-red-400 text-xs tracking-widest uppercase hover:bg-red-950 hover:border-red-600 transition-all duration-200" do %>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
        </svg>
        Revoke All
      <% end %>
    </div>

    <%# Session count %>
    <p class="text-xs text-zinc-500 tracking-widest uppercase mb-6">
      <%= pluralize(@sessions.count, "device") %> connected
    </p>

    <%# Sessions list %>
    <div class="space-y-px">
      <% @sessions.each do |session| %>
        <% is_current = session.session_token == request.session.id.to_s %>
        <div class="group relative flex items-center justify-between p-5 bg-zinc-900 hover:bg-zinc-800/80 border-l-2 <%= is_current ? 'border-emerald-500' : 'border-zinc-700 hover:border-zinc-500' %> transition-all duration-200">

          <div class="flex items-center gap-5">
            <%# Device icon %>
            <div class="w-10 h-10 flex items-center justify-center bg-zinc-800 text-lg shrink-0">
              <%= device_icon(session.device_info) %>
            </div>

            <%# Session details %>
            <div>
              <div class="flex items-center gap-3 mb-1">
                <span class="text-sm font-semibold text-zinc-100"><%= parse_device(session.device_info) %></span>
                <% if is_current %>
                  <span class="px-2 py-0.5 bg-emerald-950 border border-emerald-800 text-emerald-400 text-[10px] tracking-widest uppercase">
                    Current
                  </span>
                <% end %>
              </div>
              <div class="flex items-center gap-3 text-[11px] text-zinc-500">
                <span class="flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  </svg>
                  <%= session.ip_address %>
                </span>
                <span class="text-zinc-700">·</span>
                <span>Signed in <%= time_ago_in_words(session.created_at) %> ago</span>
                <span class="text-zinc-700">·</span>
                <span class="<%= session.expires_at < 1.day.from_now ? 'text-amber-500' : 'text-zinc-500' %>">
                  Expires <%= time_ago_in_words(session.expires_at) %>
                </span>
              </div>
            </div>
          </div>

          <%# Revoke button — hidden for current session %>
          <% unless is_current %>
            <%= button_to session_path(session),
                method: :delete,
                data: { turbo_confirm: "Remove this device?" },
                class: "opacity-0 group-hover:opacity-100 flex items-center gap-1.5 px-3 py-1.5 text-[11px] tracking-widest uppercase text-red-400 border border-red-900 hover:bg-red-950 hover:border-red-700 transition-all duration-200" do %>
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
              Revoke
            <% end %>
          <% end %>

        </div>
      <% end %>
    </div>

    <%# Empty state %>
    <% if @sessions.empty? %>
      <div class="flex flex-col items-center justify-center py-24 text-zinc-600">
        <svg class="w-12 h-12 mb-4 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        <p class="text-sm tracking-widest uppercase">No active sessions</p>
      </div>
    <% end %>

  </div>
</div>