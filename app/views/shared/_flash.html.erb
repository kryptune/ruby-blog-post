    <turbo-frame id="flash">
      <% if notice %>
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 mt-4 transition-opacity duration-500" data-controller="flash">
          <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg ">
            <%= notice %>
          </div>
        </div>
      <% end %>

      <% if alert %>
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 mt-4" data-controller="flash">
          <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg">
            <%= alert %>
          </div>
        </div>
      <% end %>
    </turbo-frame>