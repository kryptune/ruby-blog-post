<article id="blog_post_<%= blog_post.id %>" class="bg-white rounded-xl shadow-sm border border-gray-200 hover:shadow-md transition-shadow overflow-hidden group">
  <div class="h-2 bg-gradient-to-r from-blue-500 to-purple-500"></div>

  <div class="p-6">
    <h2 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-blue-600 transition-colors line-clamp-2">
      <%= link_to blog_post.title, blog_post, class: "hover:underline" %>
    </h2>

    <p class="text-gray-600 text-sm leading-relaxed mb-4 line-clamp-3 h-[42px] ">
      <%= truncate(blog_post.body, length: 80) %>
    </p>
    
    <% if (image = blog_post.images.first) && image.variable? %>
      <%= image_tag image.variant(resize_to_fill: [300, 180]) %>
    <% end %>

    <div class="flex items-center justify-between pt-4 border-t border-gray-100 mt-auto">
      <%= link_to blog_post, class: "inline-flex items-center text-blue-600 hover:text-blue-700 font-medium text-sm mr-auto" do %>
        Read more
        <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      <% end %>

      <% if blog_post.respond_to?(:created_at) %>
        <% if blog_post.draft? %>
          <span class="text-xs text-gray-400 mr-2">Draft</span>
        <% elsif blog_post.scheduled? %>
          <span class="text-xs text-yellow-400 mr-2">Scheduled</span>
        <% else %>
          <span class="text-xs text-green-400 mr-2">Published</span>
        <% end %>

        <span class="text-xs text-gray-400">
          <%= blog_post.draft? ? "" : time_ago_in_words(blog_post.published_at) %>
          <%= blog_post.draft? ? "" : Time.current - (blog_post.published_at || 0) < 0 ? "from now" : "ago" %>
        </span>
      <% end %>
    </div>
  </div>
</article>