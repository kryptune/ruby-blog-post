<div class="max-w-2xl mx-auto">
  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Edit Blog Post</h1>
    <p class="text-gray-600">Make changes to your blog post below</p>
  </div>

  <!-- Form Card -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 mb-6">
    <%= render "form", blog_post: @blog_post %>
  </div>

  <!-- Danger Zone -->
  <div class="bg-red-50 rounded-xl border-2 border-red-200 p-6">
    <h3 class="text-lg font-semibold text-red-900 mb-2">Danger Zone</h3>
    <p class="text-sm text-red-700 mb-4">
      Once you delete this blog post, there is no going back. Please be certain.
    </p>
    <%= button_to "Delete Post", @blog_post, 
        method: :delete, 
        data: { turbo_confirm: "Are you sure you want to delete this post? This action cannot be undone." },
        class: "w-full sm:w-auto px-6 py-3 bg-red-600 text-white font-semibold rounded-lg hover:bg-red-700 transition-colors" %>
  </div>
</div>