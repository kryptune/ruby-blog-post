<div class="space-y-6">
  <!-- Header Section -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-4xl font-bold text-gray-900">Blog Posts</h1>
      <p class="mt-2 text-gray-600">
        <%= link_to "All posts: #{user_signed_in? ? @blog_posts_all.count : @blog_posts_all.published.count}", blog_posts_path, class: params[:status].nil? ? "font-bold hover:text-blue-600 transition-colors" : "" %>
        <% if user_signed_in?%>
        (
        <%= link_to "Published: #{@blog_posts_all.published.count}", blog_posts_path(status: :published), class: params[:status] == "published" ? "font-bold" : "hover:text-green-600 transition-colors" %>,
        <%= link_to "Scheduled: #{@blog_posts_all.scheduled.count}", blog_posts_path(status: :scheduled), class: params[:status] == "scheduled" ? "font-bold" : "hover:text-yellow-600 transition-colors" %>,
        <%= link_to "Draft: #{@blog_posts_all.draft.count}", blog_posts_path(status: :draft), class: params[:status] == "draft" ? "font-bold" : "hover:text-red-600 transition-colors" %>
        )
        <%end%>
      </p>
    </div>

    <% if user_signed_in? %>
      <%= link_to new_blog_post_path, class: "inline-flex items-center px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors shadow-sm" do %>
        New Post
      <% end %>
    <% end %>
  </div>

  <!-- Blog Posts Grid -->
  <%= turbo_stream_from "blog_posts" %>
  <% if @blog_posts.any? %>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3" id="blog_posts">
      <%= render @blog_posts %>
    </div>
  <% else %>
    <div class="text-center py-16 bg-white rounded-xl border-2 border-dashed border-gray-300">
      <h3 class="mt-4 text-lg font-medium text-gray-900">
        <% if params[:status] == "draft" %>No draft posts yet
        <% elsif params[:status] == "scheduled" %>No scheduled posts yet
        <% else %>No published posts yet
        <% end %>
      </h3>
      <p class="mt-2 text-sm text-gray-500">Get started by creating your first blog post.</p>
    </div>
  <% end %>
</div>