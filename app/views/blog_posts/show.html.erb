<div class="max-w-4xl mx-auto">
  <!-- Back Button -->
  <%= link_to blog_posts_path, class: "inline-flex items-center text-gray-600 hover:text-gray-900 mb-6 transition-colors" do %>
    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
    </svg>
    Back to all posts
  <% end %>

  <!-- Post Card -->
  <article class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <!-- Header with Gradient -->
    <div class="h-3 bg-gradient-to-r from-blue-500 to-purple-500"></div>
    
    <!-- Post Content -->
    <div class="p-8 sm:p-12">
      <!-- Title -->
      <h1 class="text-4xl font-bold text-gray-900 mb-6 leading-tight">
        <%= @blog_post.title %>
      </h1>

      <!-- Post Meta (if you have timestamps and author) -->
      <div class="flex items-center gap-4 mb-8 pb-6 border-b border-gray-200">
        <% if @blog_post.respond_to?(:created_at) %>
          <div class="flex items-center text-sm text-gray-600">
            <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            <%= @blog_post.created_at.strftime("%B %d, %Y") %>
          </div>
        <% end %>
        
        <% if @blog_post.respond_to?(:updated_at) && @blog_post.updated_at != @blog_post.created_at %>
          <span class="text-sm text-gray-400">•</span>
          <div class="text-sm text-gray-600">
            Updated <%= time_ago_in_words(@blog_post.updated_at) %> ago
          </div>
        <% end %>
      </div>

      <!-- Post Body -->
      <div class="prose prose-lg max-w-none">
        <%= simple_format(@blog_post.body, {}, sanitize: false) %>
      </div>

      <!-- Edit Button (for logged-in users) -->
      <% if user_signed_in? %>
        <div class="mt-10 pt-8 border-t border-gray-200">
          <%= link_to edit_blog_post_path(@blog_post), 
              class: "inline-flex items-center px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors shadow-sm" do %>
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
            </svg>
            Edit Post
          <% end %>
        </div>
      <% end %>
    </div>
  </article>

  <%= turbo_stream_from [@blog_post, :comments] %>
  <%= render "comments/form", blog_post: @blog_post, comment: @blog_post.comments.build%>
  <div id="comments">
    <%= render @comments, user_signed_in: user_signed_in? %>
  </div>

  <div class="mt-8 bg-gray-50 rounded-xl border border-gray-200 p-8">
    <h3 class="text-xl font-bold text-gray-900 mb-4">Enjoyed this post?</h3>
    <p class="text-gray-600 mb-4">Check out more articles on our blog.</p>
    <%= link_to root_path, 
        class: "inline-flex items-center text-blue-600 hover:text-blue-700 font-medium" do %>
      Browse all posts
      <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
    <% end %>
  </div>
</div>