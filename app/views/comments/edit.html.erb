<turbo-frame id="comments">
  <div class="max-w-2xl mx-auto">
    <%= link_to blog_post_path(@blog_post), class: "inline-flex items-center text-gray-600 hover:text-gray-900 mb-6 transition-colors" do %>
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      Back to post
    <% end %>

    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">Edit Comment</h1>
      <p class="text-gray-600">Make changes to your comment below</p>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
      <%= render "form" %>
    </div>
  </div>
</turbo-frame>