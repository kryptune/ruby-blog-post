<turbo-frame id="new_comment">
  <%= form_with model: [blog_post, comment], class:"my-4" do |form| %>
    <div class="mb-4">
      <%= form.label :body, "Comment", class: "block text-sm font-semibold text-gray-700 mb-2" %>
      <%= form.text_area :body, 
          rows: 5,
          class: "w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all",
          placeholder: "Write your comment here...",
          required: true %>
      
      <% if comment.errors[:body].any? %>
        <p class="text-red-600 text-sm mt-1">
          <%= comment.errors[:body].first %>
        </p>
      <% end %>
    </div>

    <%= form.submit comment.persisted? ? "Update Comment" : "Post Comment", 
        class: "w-full sm:w-auto px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors shadow-sm" %>
  <% end %>
</turbo-frame>
